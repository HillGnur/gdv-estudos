mindmap
  root["Capítulo 06 – Um Pouco Mais de Visual: Semiótica e Gestalt"]
    s1["1. Semiótica"]
      s1_1["Estuda como sentidos são construídos"]
      s1_2["Não se limita à linguagem verbal"]
      s1_3["Tem base relevante em Charles Sanders Peirce"]
      s1_4["Um coração vermelho na HUD pode significar 'vida' sem texto algum."]
      s1_5["Um som curto e metálico ao pegar moeda comunica 'recompensa' antes mesmo do jogador olhar o placar."]
    s2["2. Tríades de Peirce"]
      s2_1["Signo: aquilo que representa"]
      s2_2["Objeto: aquilo que é representado"]
      s2_3["Interpretante: efeito de sentido gerado"]
      s2_4["Signo: barra vermelha piscando."]
      s2_5["Objeto: estado real de pouca vida do personagem."]
    s3["3. Regras das Tricotomias"]
      s3_1["Nem toda combinação é válida: algumas dependem de níveis anteriores de experiência e interpretação."]
      s3_2["Em design, isso ajuda a evitar signos confusos: primeiro gerar sensação clara, depois fato perceptível, depois convenção"]
      s3_3["Exemplo: efeito visual chamativo (primeiridade), impacto do dano no personagem (secundidade) e padrão aprendido 'efeito"]
    s4["4. Introdução à Gestalt"]
      s4_1["Semelhança"]
      s4_2["Proximidade"]
      s4_3["Continuidade"]
      s4_4["Pregnância"]
      s4_5["Fechamento"]
    s5["5. Síntese"]
      s5_1["Semiótica ajuda a escolher 'o que comunicar' e 'como isso vira significado'."]
      s5_2["Gestalt ajuda a organizar 'como isso é percebido rapidamente'."]
      s5_3["Juntas, as duas abordagens melhoram clareza, tempo de reação e consistência visual no jogo."]
    exemplos["Exemplos praticos"]
      ex1["Exemplo: aplicar o conceito em uma micro cena de jogo."]
      ex2["Exemplo: revisar com pessoa leiga para simplificar linguagem."]
